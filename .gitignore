# Python
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments
.venv/
venv/
env/
ENV/

# Environment/config secrets
.env
.env.*
!.env.example
config/db_config.json

# Dataset files - do not commit Kaggle data
data/
*.csv
*.tsv
*.zip
*.gz
*.rar
*.7z

# Large/generated Mongo exports
*.bson
*.jsonl
*.ndjson
dump/
exports/

# Jupyter
.ipynb_checkpoints/

# Results generated after running queries
results/query_outputs/*
!results/query_outputs/.gitkeep

results/metabase_screenshots/*
!results/metabase_screenshots/.gitkeep

# Logs
*.log
logs/

# OS/editor files
.DS_Store
Thumbs.db
.vscode/
.idea/

# Node/Metabase or frontend leftovers if any
node_modules/
dist/
build/

# Temporary files
tmp/
temp/
*.tmp
*.bak
*.swp